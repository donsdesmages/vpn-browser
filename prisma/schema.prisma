generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WebUser {
  id               Int           @id @default(autoincrement())
  email            String        @unique
  passwordHash     String        @map("password_hash")
  phone            String?
  telegramUsername String?       @map("telegram_username")
  contactType      String?       @map("contact_type")
  telegramChatId   BigInt?       @map("telegram_chat_id")
  linkedEmail      String?       @unique @map("linked_email")
  accessKey          String?       @map("access_key")
  subscriptionStart  DateTime?     @map("subscription_start")
  durationDays       Int?          @map("duration_days")
  createdAt          DateTime      @default(now()) @map("created_at")
  otpTokens        WebOtpToken[]

  @@map("web_users")
}

model WebOtpToken {
  id         Int      @id @default(autoincrement())
  webUserId  Int      @map("web_user_id")
  token      String   @unique
  tokenType  String   @map("token_type")
  code       String?
  expiresAt  DateTime @map("expires_at")
  used       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  user       WebUser  @relation(fields: [webUserId], references: [id], onDelete: Cascade)

  @@map("web_otp_tokens")
}
